DATABASE_URL="postgresql://postgres:postgres@localhost:5432/digitale_behoerde"
# Optionaler lokaler Development-Wert. In Produktion ist ein externes Secret zwingend.
JWT_SECRET=""
PORT=3001
NODE_ENV="development"
CORS_ORIGIN="http://localhost:3000"

# Ablage fuer hochgeladene Dokumente: "local" oder "azure"
DOCUMENT_STORAGE="local"
# Nur relevant bei DOCUMENT_STORAGE="local": Zielordner
UPLOAD_DIR="./uploads"
# Nur relevant bei DOCUMENT_STORAGE="azure": Storage-Account-Name
AZURE_STORAGE_ACCOUNT=""
# Nur relevant bei DOCUMENT_STORAGE="azure": Container-Name
AZURE_STORAGE_CONTAINER="application-documents"
