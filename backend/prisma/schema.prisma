// Prisma-Schema fuer die Digitale Behoerde.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CITIZEN
  CASEWORKER
}

enum ApplicationType {
  RESIDENCE_CHANGE
  DOG_TAX
  CERTIFICATE_OF_CONDUCT
}

enum ApplicationStatus {
  SUBMITTED
  IN_REVIEW
  APPROVED
  REJECTED
}

enum DocumentType {
  OTHER
  IDENTITY_DOCUMENT
  LANDLORD_CONFIRMATION
  MOVE_IN_CONFIRMATION
}

model User {
  id           String        @id @default(uuid())
  email        String        @unique
  passwordHash String        @map("password_hash")
  role         Role          @default(CITIZEN)
  firstName    String?       @map("first_name")
  lastName     String?       @map("last_name")
  birthDate    DateTime?     @map("birth_date") @db.Date
  birthPlace   String?       @map("birth_place")
  street       String?
  postalCode   String?       @map("postal_code")
  city         String?
  createdAt    DateTime      @default(now()) @map("created_at")
  applications Application[]

  @@map("users")
}

model Application {
  id                   String                @id @default(uuid())
  type                 ApplicationType
  status               ApplicationStatus     @default(SUBMITTED)
  userId               String                @map("user_id")
  createdAt            DateTime              @default(now()) @map("created_at")
  updatedAt            DateTime              @updatedAt @map("updated_at")
  user                 User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  residenceChange      ResidenceChange?
  dogTax               DogTax?
  certificateOfConduct CertificateOfConduct?
  documents            Document[]

  @@index([userId, createdAt])
  @@map("applications")
}

model Document {
  id            String       @id @default(uuid())
  applicationId String       @map("application_id")
  originalName  String       @map("original_name")
  storedName    String       @unique @map("stored_name")
  mimeType      String       @map("mime_type")
  type          DocumentType @default(OTHER)
  size          Int
  uploadedAt    DateTime     @default(now()) @map("uploaded_at")
  application   Application  @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
  @@map("documents")
}

model ResidenceChange {
  id            String      @id @default(uuid())
  applicationId String      @unique @map("application_id")
  moveDate      DateTime    @map("move_date") @db.Date
  oldStreet     String      @map("old_street")
  oldPostalCode String      @map("old_postal_code")
  oldCity       String      @map("old_city")
  newStreet     String      @map("new_street")
  newPostalCode String      @map("new_postal_code")
  newCity       String      @map("new_city")
  householdSize Int         @default(1) @map("household_size")
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@map("residence_changes")
}

model DogTax {
  id              String      @id @default(uuid())
  applicationId   String      @unique @map("application_id")
  dogName         String      @map("dog_name")
  dogBreed        String?     @map("dog_breed")
  dogBirthDate    DateTime?   @map("dog_birth_date") @db.Date
  chipNumber      String?     @map("chip_number")
  ownerStreet     String      @map("owner_street")
  ownerPostalCode String      @map("owner_postal_code")
  ownerCity       String      @map("owner_city")
  taxStartDate    DateTime    @map("tax_start_date") @db.Date
  application     Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@map("dog_taxes")
}

model CertificateOfConduct {
  id            String      @id @default(uuid())
  applicationId String      @unique @map("application_id")
  purpose       String
  deliveryType  String      @map("delivery_type")
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@map("certificate_of_conducts")
}
